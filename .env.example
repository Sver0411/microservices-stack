# ═══════════════════════════════════════════════
# Microservices Stack — Environment Variables
# ═══════════════════════════════════════════════
# Copy to .env and fill in your values.
# Never commit .env to version control!

# ── Laptop Booking ──
LAPTOP_ADMIN_PASSWORD=your-secure-password-here
FEISHU_WEBHOOK=

# ── Blog Backend ──
SITE_URL=https://example.com

# ── Library API ──
LIBRARY_SECRET_KEY=your-strong-random-secret-key
CORS_ORIGINS=*

# ── SSL (optional) ──
# Place fullchain.pem and privkey.pem in ./ssl/
